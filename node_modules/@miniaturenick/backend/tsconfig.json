{
  "ts-node": {
    "files": true,
    "transpileOnly": true
  },
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "strict": true,

    "skipLibCheck": true,
    "sourceMap": true,
    "inlineSources": true,

    "resolveJsonModule": true,
    "isolatedModules": false,

    "lib": ["ES2021"],
    "target": "ES2021",
    "types": ["node"],

    "module": "Node16",
    "moduleResolution": "node16"
  },
  "include": ["src"]
}
