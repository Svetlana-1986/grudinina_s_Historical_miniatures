{
  "name": "@miniaturenick/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "rimraf ./dist && tsc",
    "start": "node ./dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prepare": "npm run prisma:generate",
    "types": "tsc --noEmit",
    "lint": "eslint --ext .ts ."
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "prisma": "6.19.3",
    "tsx": "^4.22.3"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@supabase/supabase-js": "^2.109.0",
    "@trpc/server": "^11.17.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "4.18.2",
    "lodash": "^4.18.1",
    "multer": "^2.1.1",
    "sharp": "^0.35.1",
    "superjson": "^2.2.6",
    "transliteration": "^2.6.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./createCard/input": {
      "types": "./dist/router/createCard/input.d.ts",
      "default": "./dist/router/createCard/input.js"
    },
    "./signUp/input": {
      "types": "./dist/router/signUp/input.d.ts",
      "default": "./dist/router/signUp/input.js"
    },
    "./signIn/input": {
      "types": "./dist/router/signIn/input.d.ts",
      "default": "./dist/router/signIn/input.js"
    }
  }
}
