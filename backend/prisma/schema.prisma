
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HistoricalPeriod {
  ANCIENT
  MIDDLE_AGES
  NAPOLEONIC_WARS
  WORLD_WAR_1
  WORLD_WAR_2
  FANTASY
  OTHER
}


model User {
  id String @id @default(uuid())
  nick String @unique
  displayName String
  passwordHash String
  createdAt DateTime @default(now())
  sessions Session[]
  cards Card[]
}


model Card {
  id String @id @default(uuid())
  slug String @unique
  title String
  historicalPeriod HistoricalPeriod
  coverImage String?
  coverImagePreview String?
  coverImageHero String?
  images CardImage[]
  description String
  createdAt DateTime @default(now())
  authorId String
  author User @relation(fields: [authorId], references: [id])
}

model CardImage {
  id String @id @default(cuid())
  imageUrl String
  position Int @default(0)
  cardId String
  card Card @relation(fields: [cardId], references: [id])
  createdAt DateTime @default(now())
}

model Session {
  id String @id @default(uuid())
  token String @unique
  userId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  @@index([token])
}

