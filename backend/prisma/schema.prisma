
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  nick           String   @unique
  passwordHash   String
  createdAt      DateTime @default(now())
}




model Card {
  id               String @id @default(uuid())
  slug             String @unique
  title            String
  historicalPeriod String
  authorNick       String
  authorName       String
  description      String
  createdAt        DateTime @default(now())
}

