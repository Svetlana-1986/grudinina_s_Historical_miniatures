{
  "ts-node": {
    "files": true,
    "transpileOnly": true
  },

  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2021",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2021"],

    "types": ["node"],

    "strict": true,

    "noImplicitAny": true,

    "forceConsistentCasingInFileNames": true,

    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "inlineSources": true,

    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,

    "esModuleInterop": true,
    
    "declaration": true,
    "declarationMap": true
  },

  "include": ["src"]
}
