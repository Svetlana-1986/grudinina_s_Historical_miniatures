{
  "name": "miniaturenick",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "backend",
    "webapp"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "dev:webapp": "npm run dev --workspace webapp",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:webapp\"",
    "types:backend": "npm run types --workspace backend",
    "types:webapp": "npm run types --workspace webapp",
    "types": "concurrently \"npm run types:backend\" \"npm run types:webapp\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
